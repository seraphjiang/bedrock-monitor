{
  "name": "bedrock-monitor",
  "version": "0.1.0",
  "description": "AWS Bedrock usage analytics — ingest to OpenSearch/S3, dashboards for usage, model comparison, and audit",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "ingest": "npx tsx src/ingestion/cloudwatch-to-opensearch.ts",
    "pull-metrics": "npx tsx scripts/pull-metrics.ts",
    "generate-test-data": "npx tsx scripts/generate-test-invocations.ts",
    "export-dashboards": "npx tsx scripts/export-dashboards.ts",
    "load-local": "npx tsx scripts/load-to-local-opensearch.ts",
    "setup-logging": "npx tsx scripts/setup-bedrock-logging.ts"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock": "^3.700.0",
    "@aws-sdk/client-bedrock-runtime": "^3.700.0",
    "@aws-sdk/client-cloudwatch": "^3.700.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.700.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@opensearch-project/opensearch": "^2.12.0",
    "aws-cdk-lib": "^2.250.0",
    "constructs": "^10.6.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "ts-node": "^10.9.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0"
  }
}
