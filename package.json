{
  "name": "bedrock-monitor",
  "version": "0.1.0",
  "description": "AWS Bedrock usage analytics — ingest to OpenSearch/S3, dashboards for usage, model comparison, and audit",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "ingest": "node --loader ts-node/esm src/ingestion/cloudwatch-to-opensearch.ts",
    "generate-test-data": "node --loader ts-node/esm scripts/generate-test-invocations.ts",
    "export-dashboards": "node --loader ts-node/esm scripts/export-dashboards.ts",
    "setup-logging": "node --loader ts-node/esm scripts/setup-bedrock-logging.ts"
  },
  "dependencies": {
    "@aws-sdk/client-bedrock": "^3.700.0",
    "@aws-sdk/client-bedrock-runtime": "^3.700.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.700.0",
    "@aws-sdk/client-cloudwatch": "^3.700.0",
    "@aws-sdk/client-s3": "^3.700.0",
    "@opensearch-project/opensearch": "^2.12.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "ts-node": "^10.9.0",
    "@types/node": "^22.0.0"
  }
}
